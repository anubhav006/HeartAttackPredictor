# Environment Variables for HeartAttackPredictor
# Copy this file to .env and fill in your actual values

# Flask Secret Key (change this to a random string in production)
SECRET_KEY=your_secret_key_here

# Database Configuration
# For local development (SQLite):
DATABASE_URL=sqlite:///heart_data.db

# For Render PostgreSQL (replace with your actual database URL from Render dashboard):
# DATABASE_URL=postgresql://your_username:your_password@your_host/your_database

# Model file path
MODEL_PATH=heart_attack_model.pkl

# Flask configuration
FLASK_APP=app.py
FLASK_DEBUG=True